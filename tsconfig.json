{
  "compilerOptions": {
    "sourceMap": true,
    "module": "ESNext",
    "target": "ES6",
    "jsx": "react-jsx",
    "noImplicitAny": false,
    "experimentalDecorators": true,
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "types": [
      "node"
    ],
    "typeRoots": [
      "./node_modules/@types"
    ]
  },
  "include": ["src"]
}
